# Application Configuration
APP_NAME=VoxForge AI
DEBUG=False
APP_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql://voxforge_admin:voxforge_secure_pass_1025@localhost:5432/voxforge_db

# Redis/Cache
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Authentication
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Storage
MAX_UPLOAD_SIZE=20971520  # 20MB in bytes
UPLOAD_DIR=app/generated_audio
ALLOWED_AUDIO_FORMATS=mp3,wav,flac

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8501,http://localhost:7860

# AI/API Keys
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: AWS S3 for Production
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET_NAME=voxforge-ai-audio

